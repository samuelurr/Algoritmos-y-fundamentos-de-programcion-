Algoritmo ejercicio_16
	Limpiar Pantalla
	
	Escribir ""
	Escribir "captura de numeros ..."
	Escribir ""
	
	Definir cantNumeros Como Entero
	Escribir "cuantos numeros quieres capturar ?" Sin Saltar
	Leer cantNumeros
	
	Definir M Como Entero
	dimension vNumero[cantNumeros]
	Escribir ""
	Escribir "captura de numeros ..."
	Escribir ""
	Escribir "presione para continuar ..."
	Esperar Tecla
	
	Escribir ""
